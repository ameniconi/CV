<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
  <script>
    (function(w,d,s,l,i){w[l]=w[l]||[];
      w[l].push({'gtm.start': new Date().getTime(),event:'gtm.js'});
      var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
      j.async=true;
      j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
      f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MBMHVRG5');
  </script>
  <!-- End Google Tag Manager -->

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="{{ keywords }}">
  <meta name="author" content="Angelo Meniconi">

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ og_title or title }}">
  <meta property="og:description" content="{{ og_description or description }}">
  <meta propert1e" content="website">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:image" content="https://angelomeniconi.co.uk/favicon.ico">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ og_title or title }}">
  <meta name="twitter:description" content="{{ og_description or description }}">
  <meta name="twitter:image" content="https://angelomeniconi.co.uk/favicon.ico">

<link rel="stylesheet" href="/css/styles.css">
<link rel="icon" href="/favicon.ico">

  <!-- Google Analytics (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8S0STDPBKR"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-8S0STDPBKR');
  </script>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@400;600&family=Merriweather:wght@400;700&display=swap" rel="stylesheet">
  <!-- CookieConsent CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cookieconsent@3/build/cookieconsent.min.css" />
</head>

<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MBMHVRG5"
      height="0" width="0" style="display:none;visibility:hidden">
    </iframe>
  </noscript>
  <!-- End Google Tag Manager (noscript) -->

  {% include "nav.njk" %}

  <main class="content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}
  <script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.querySelector('.nav');

  toggle.addEventListener('click', () => {
    nav.classList.toggle('active');
  });
</script>

  <!-- CookieConsent JS -->
<script src="https://cdn.jsdelivr.net/npm/cookieconsent@3/build/cookieconsent.min.js"></script>
<script>
window.addEventListener("load", function(){
  window.cookieconsent.initialise({
    palette: {
      popup: { 
        background: "#ffffff",  // white background
        text: "#000000"         // black text
      },
      button: { 
        background: "#1e3a8a",  // your primary button color
        text: "#ffffff"          // white text
      }
    },
    theme: "classic",
    type: "opt-in",
    content: {
      message: "This site uses cookies for analytics and performance.",
      dismiss: "Accept",
      deny: "Reject",
      link: "Learn more",
      href: "/cookie-policy/"
    },
    onInitialise: function(status) {
      setGTMConsent(status);
    },
    onStatusChange: function(status) {
      setGTMConsent(status);
    }
  });
});

function setGTMConsent(status) {
  // Push consent event to dataLayer
  if (window.dataLayer) {
    if (status === 'allow') {
      dataLayer.push({ event: 'cookie_consent', analytics_consent: 'granted' });
    } else {
      dataLayer.push({ event: 'cookie_consent', analytics_consent: 'denied' });
    }
  }
}
</script>

</body>
</html>
