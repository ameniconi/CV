<!DOCTYPE html>
<html lang="en">
<head>

  <!-- ========================= -->
  <!-- Consent Mode (DEFAULT) -->
  <!-- ========================= -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    // Default consent: denied
    gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied'
    });
  </script>

  <!-- ========================= -->
  <!-- Google Tag Manager -->
  <!-- ========================= -->
  <script>
    (function(w,d,s,l,i){w[l]=w[l]||[];
      w[l].push({'gtm.start': new Date().getTime(),event:'gtm.js'});
      var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
      j.async=true;
      j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
      f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MBMHVRG5');
  </script>
  <!-- End Google Tag Manager -->

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="{{ keywords }}">
  <meta name="author" content="Angelo Meniconi">

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ og_title or title }}">
  <meta property="og:description" content="{{ og_description or description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:image" content="https://angelomeniconi.co.uk/favicon.ico">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ og_title or title }}">
  <meta name="twitter:description" content="{{ og_description or description }}">
  <meta name="twitter:image" content="https://angelomeniconi.co.uk/favicon.ico">

  <link rel="stylesheet" href="/css/styles.css">
  <link rel="icon" href="/favicon.ico">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@400;600&family=Merriweather:wght@400;700&display=swap" rel="stylesheet">

  <!-- CookieConsent CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cookieconsent@3/build/cookieconsent.min.css" />

</head>

<body>

  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MBMHVRG5"
      height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>

  {% include "nav.njk" %}

  <main class="content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  <!-- Mobile nav -->
  <script>
    const toggle = document.querySelector('.nav-toggle');
    const nav = document.querySelector('.nav');
    if (toggle) {
      toggle.addEventListener('click', () => {
        nav.classList.toggle('active');
      });
    }
  </script>

  <!-- ========================= -->
  <!-- Accent palette -->
  <!-- ========================= -->
  <script>
    (function () {
      const palettes = [
        { accent: '#1e3a8a', hover: '#162c6b' },
        { accent: '#0f766e', hover: '#115e59' },
        { accent: '#7c2d12', hover: '#9a3412' },
        { accent: '#334155', hover: '#1e293b' }
      ];

      let index = localStorage.getItem('accentPalette');

      if (index === null || !palettes[index]) {
        index = Math.floor(Math.random() * palettes.length);
        localStorage.setItem('accentPalette', index);
      }

      const choice = palettes[index];
      const root = document.documentElement;

      root.style.setProperty('--color-accent', choice.accent);
      root.style.setProperty('--color-accent-hover', choice.hover);
    })();
  </script>

  <!-- ========================= -->
  <!-- CookieConsent -->
  <!-- ========================= -->
  <script src="https://cdn.jsdelivr.net/npm/cookieconsent@3/build/cookieconsent.min.js"></script>
  <script>
    window.addEventListener("load", function(){
      window.cookieconsent.initialise({
        palette: {
          popup: {
            background: "#ffffff",
            text: "#000000"
          },
          button: {
            background: getComputedStyle(document.documentElement)
              .getPropertyValue('--color-accent').trim(),
            text: "#ffffff"
          }
        },
        theme: "classic",
        type: "opt-in",
        content: {
          message: "This site uses cookies for analytics and performance.",
          allow: "Got it!",
          deny: "No thanks",
          link: "More info",
          href: "/cookie-policy/"
        },
        onInitialise: function(status) {
          updateConsent(status);
        },
        onStatusChange: function(status) {
          updateConsent(status);
        }
      });
    });

    function updateConsent(status) {
      if (status === 'allow') {
        gtag('consent', 'update', {
          analytics_storage: 'granted',
          ad_storage: 'denied'
        });
      } else {
        gtag('consent', 'update', {
          analytics_storage: 'denied',
          ad_storage: 'denied'
        });
      }
    }
  </script>

</body>
</html>
